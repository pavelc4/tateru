#!/usr/bin/env bash
_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export TATERU_ROOT="$_ROOT"
export TATERU_CLANG="$_ROOT/prebuilts-master/clang/host/linux-x86/clang-r510928/bin"
export TATERU_PREBUILTS="$_ROOT/prebuilts/kernel-build-tools/linux-x86/bin"

if [ -f "$_ROOT/tateru/bin/tateru" ]; then
    export PATH="$_ROOT/tateru/bin:$PATH"
fi
echo "Tateru env loaded — workspace: $TATERU_ROOT"
